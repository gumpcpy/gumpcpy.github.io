# Copy to .env.company and fill in real values:
#   cp .env.company.example .env.company

# SSH target (user@host)
COMPANY_SSH_HOST=user@your-server.example.com

# nginx root on server (see install notes: /var/www/huhu_site)
COMPANY_SSH_PATH=/var/www/huhu_site

# Optional
COMPANY_SSH_PORT=22
# COMPANY_SSH_KEY=~/.ssh/id_ed25519
